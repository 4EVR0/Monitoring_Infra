# dq_api 실행 환경변수 예시 (실제 값은 .env로 복사, 커밋 금지)

# Iceberg 메타데이터 S3 경로 (oliveyoung_db 워밍업) — 필수
ICEBERG_WAREHOUSE_PATH=s3://your-bucket/iceberg_metadata/

# AWS 리전
AWS_REGION=ap-northeast-2

# 조회 대상 테이블 (기본값과 같으면 생략 가능)
DQ_METRICS_TABLE=oliveyoung_db.dq_metrics

# AWS 자격증명은 EC2 IAM Role 사용 권장. 로컬 테스트 시에만 아래 사용:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
