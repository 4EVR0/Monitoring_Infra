{
  "title": "Oliveyoung 데이터 정합성",
  "uid": "oliveyoung-dataquality",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": {"from": "now-30d", "to": "now"},
  "timezone": "browser",
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "매핑 품질 (silver→gold)",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6, "spanNulls": true, "fillOpacity": 0, "thresholdsStyle": {"mode": "line"}},
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.85},
            {"color": "green", "value": 0.95}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 1},
      "id": 2,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "description": "silver→gold 단계 INCI 매핑률. 실행마다 한 점. 급락 시 성분 사전/소스 변동 의심.",
      "title": "INCI 매핑률 (silver→gold)",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"silver_to_gold\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap match_rate [$__interval])",
          "legendFormat": "match_rate",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6, "spanNulls": true, "fillOpacity": 0},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "description": "unique 성분 대비 INCI 매핑 성공/실패 건수.",
      "title": "성분 매핑 건수 (silver→gold)",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"silver_to_gold\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap ingredients_unique [$__interval])",
          "legendFormat": "unique",
          "refId": "A"
        },
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"silver_to_gold\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap ingredients_matched [$__interval])",
          "legendFormat": "matched",
          "refId": "B"
        },
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"silver_to_gold\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap ingredients_unmatched [$__interval])",
          "legendFormat": "unmatched",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 9},
      "id": 4,
      "title": "전처리 · 적재 보존 (bronze→silver)",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6, "spanNulls": true, "fillOpacity": 0},
          "unit": "short",
          "min": 0
        },
        "overrides": [
          {"matcher": {"id": "byName", "options": "error"}, "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]}
        ]
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 10},
      "id": 5,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "description": "bronze 로드 → 정상/에러. 전처리 통과·유실 추세. (정상+에러가 로드와 단순합이 안 맞을 수 있음 — 중복/에러 카운트 기준 관찰)",
      "title": "bronze→silver 행 흐름",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"bronze_to_silver\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap bronze_loaded [$__interval])",
          "legendFormat": "bronze_loaded",
          "refId": "A"
        },
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"bronze_to_silver\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap silver_ok [$__interval])",
          "legendFormat": "silver_ok",
          "refId": "B"
        },
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"bronze_to_silver\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap silver_error [$__interval])",
          "legendFormat": "error",
          "refId": "C"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6, "spanNulls": true, "fillOpacity": 0},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 10},
      "id": 6,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "description": "적재 보존: 크롤 수집 상품수 ≈ bronze 로드여야 함 (둘 다 dedup 전). 벌어지면 S3 write↔read 유실 의심. (run 정렬은 대략적 — 최신값 비교)",
      "title": "적재 보존: crawl 상품수 vs bronze 로드",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"crawl\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap products_total [$__interval])",
          "legendFormat": "crawl products",
          "refId": "A"
        },
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"bronze_to_silver\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap bronze_loaded [$__interval])",
          "legendFormat": "bronze loaded",
          "refId": "B"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 18},
      "id": 7,
      "title": "수집 안정성 (crawl)",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6, "spanNulls": true, "fillOpacity": 0},
          "unit": "short",
          "min": 0
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 19},
      "id": 8,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "description": "크롤 수집 상품 수 추이. 직전 대비 급락이면 크롤 결함 의심.",
      "title": "수집 상품 수 (crawl)",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"crawl\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap products_total [$__interval])",
          "legendFormat": "products_total",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "loki", "uid": "${loki_datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "custom": {"drawStyle": "line", "lineWidth": 2, "showPoints": "always", "pointSize": 6, "spanNulls": true, "fillOpacity": 0, "thresholdsStyle": {"mode": "line"}},
          "unit": "short",
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "red", "value": 1}
          ]}
        },
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 19},
      "id": 9,
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "description": "이동 실패 카테고리 / 0건 카테고리 수. >0이면 카테고리 누락 — 거의 항상 크롤 결함 신호.",
      "title": "카테고리 실패 / 0건 (crawl)",
      "targets": [
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"crawl\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap categories_failed [$__interval])",
          "legendFormat": "failed",
          "refId": "A"
        },
        {
          "datasource": {"type": "loki", "uid": "${loki_datasource}"},
          "expr": "last_over_time({job=\"airflow\", task_id=\"crawl\"} |= `\"DQ\"` | regexp `(?P<dq>\\{\".*\\})` | line_format `{{ .dq }}` | json | unwrap categories_zero [$__interval])",
          "legendFormat": "zero",
          "refId": "B"
        }
      ],
      "type": "timeseries"
    }
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Loki",
        "name": "loki_datasource",
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  }
}
