{
  "title": "Airflow 모니터링",
  "uid": "airflow-monitoring",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "title": "Airflow 앱 메트릭",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "title": "스케줄러 Heartbeat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "airflow_scheduler_heartbeat",
          "legendFormat": "heartbeat",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "ms",
          "links": [
            {
              "title": "Loki — DAG 로그 보기",
              "url": "/explore?orgId=1&left={\"datasource\":\"${loki_datasource}\",\"queries\":[{\"expr\":\"{job=\\\"airflow\\\",dag_id=\\\"${__field.labels.dag_id}\\\"}\",\"refId\":\"A\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": true
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 10, "x": 4, "y": 1},
      "id": 3,
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "description": "DAG 실행 완료까지 걸린 시간. StatsD timer 기반으로, 표시값은 최근 수집 구간의 중간값(p50)이야. 개별 실행 건별 기록은 Pushgateway 도입 후 가능.",
      "title": "DAG 성공 실행시간 (p50, ms)",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "airflow_dagrun_duration_success{dag_id=~\"$dag_id\",quantile=\"0.5\"}",
          "legendFormat": "{{dag_id}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "ms",
          "links": [
            {
              "title": "Loki — DAG 로그 보기",
              "url": "/explore?orgId=1&left={\"datasource\":\"${loki_datasource}\",\"queries\":[{\"expr\":\"{job=\\\"airflow\\\",dag_id=\\\"${__field.labels.dag_id}\\\"}\",\"refId\":\"A\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": true
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 10, "x": 14, "y": 1},
      "id": 4,
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "description": "실패한 DAG 실행의 소요시간. 실패까지 걸린 시간이므로 성공 실행시간보다 짧을 수 있음. 마찬가지로 p50 중간값.",
      "title": "DAG 실패 실행시간 (p50, ms)",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "airflow_dagrun_duration_failed{dag_id=~\"$dag_id\",quantile=\"0.5\"}",
          "legendFormat": "{{dag_id}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "ms",
          "links": [
            {
              "title": "Loki — 태스크 로그 보기",
              "url": "/explore?orgId=1&left={\"datasource\":\"${loki_datasource}\",\"queries\":[{\"expr\":\"{job=\\\"airflow\\\",dag_id=\\\"${__field.labels.dag_id}\\\",task_id=\\\"${__field.labels.task_id}\\\"}\",\"refId\":\"A\"}],\"range\":{\"from\":\"${__from}\",\"to\":\"${__to}\"}}",
              "targetBlank": true
            }
          ]
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 5},
      "id": 5,
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "description": "태스크별 실행 소요시간 (p50). dag_id / task_id 조합으로 표시. 특정 태스크가 느려지는 추이를 파악할 때 유용.",
      "title": "태스크 실행시간 (p50, ms)",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "airflow_task_duration{dag_id=~\"$dag_id\",quantile=\"0.5\"}",
          "legendFormat": "{{dag_id}} / {{task_id}}",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 11},
      "id": 6,
      "title": "시스템 리소스 (Airflow EC2)",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 12, "x": 0, "y": 12},
      "id": 7,
      "options": {
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "title": "CPU 사용률",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "100 - (avg(irate(node_cpu_seconds_total{job=\"airflow-node\",mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "percent",
          "min": 0,
          "max": 100
        },
        "overrides": []
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 12},
      "id": 8,
      "options": {
        "tooltip": {"mode": "single"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "title": "메모리 사용률",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "(1 - node_memory_MemAvailable_bytes{job=\"airflow-node\"} / node_memory_MemTotal_bytes{job=\"airflow-node\"}) * 100",
          "legendFormat": "Memory %",
          "refId": "A"
        }
      ],
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          }
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 18},
      "id": 9,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false}
      },
      "title": "디스크 사용률",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "100 - (node_filesystem_avail_bytes{job=\"airflow-node\",mountpoint=\"/\"} / node_filesystem_size_bytes{job=\"airflow-node\",mountpoint=\"/\"} * 100)",
          "legendFormat": "Disk %",
          "refId": "A"
        }
      ],
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 1, "fillOpacity": 10},
          "unit": "Bps"
        },
        "overrides": []
      },
      "gridPos": {"h": 4, "w": 18, "x": 6, "y": 18},
      "id": 10,
      "options": {
        "tooltip": {"mode": "multi"},
        "legend": {"displayMode": "list", "placement": "bottom"}
      },
      "title": "네트워크 트래픽",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "irate(node_network_receive_bytes_total{job=\"airflow-node\",device!~\"lo|docker.*\"}[5m])",
          "legendFormat": "in / {{device}}",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${datasource}"},
          "expr": "irate(node_network_transmit_bytes_total{job=\"airflow-node\",device!~\"lo|docker.*\"}[5m])",
          "legendFormat": "out / {{device}}",
          "refId": "B"
        }
      ],
      "type": "timeseries"
    }
  ],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "label": "Data Source",
        "name": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "label": "Loki",
        "name": "loki_datasource",
        "query": "loki",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "datasource": {"type": "prometheus", "uid": "${datasource}"},
        "definition": "label_values(airflow_dagrun_duration_success, dag_id)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "label": "DAG",
        "name": "dag_id",
        "query": {
          "query": "label_values(airflow_dagrun_duration_success, dag_id)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  }
}
